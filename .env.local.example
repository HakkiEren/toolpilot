# ============================================================
# ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (for content generation pipeline)
OPENAI_API_KEY=sk-your-key

# Anthropic (for content generation pipeline)
ANTHROPIC_API_KEY=sk-ant-your-key

# Google Analytics (GA4)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# Search Engine Verification (get from Search Console / Bing Webmaster Tools)
NEXT_PUBLIC_GSC_ID=your-google-verification-code
NEXT_PUBLIC_BING_ID=your-bing-verification-code

# Google Search Console API (for monitoring)
GSC_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
